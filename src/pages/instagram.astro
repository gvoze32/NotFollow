---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import UploadCard from "../components/upload/UploadCard.astro";
import FileInput from "../components/upload/FileInput.astro";
import HowToModal from "../components/HowToModal.astro";
import NonFollowersResults from "../components/results/NonFollowersResults.astro";
---

<Layout title="Instagram NotFollow - Check Who Doesn't Follow You Back">
  <Navbar />

  <PageHero
    title="Instagram NotFollow"
    subtitle="Upload your Instagram data files to discover who doesn't follow you back"
  />

  <UploadCard>
    <FileInput
      id="followersFile"
      label="Followers Files"
      accept=".json"
      multiple
      hint="Select one or more followers_*.json files"
    />
    <FileInput
      id="followingFile"
      label="Following File"
      accept=".json"
      multiple
      hint="Select your following.json file"
    />
  </UploadCard>

  <NonFollowersResults platformName="Instagram" />

  <Footer />

  <HowToModal
    title="How to Get JSON Files"
    videoId="4eh8eJAUEdk"
    videoTitle="How to download Instagram data (NotFollow tutorial)"
  />

  <script>
    import {
      createNotFollowPage,
      initModals,
      onFileChange,
      setError,
      type Account,
    } from "../scripts/notfollow-page";

    initModals();

    const page = createNotFollowPage({
      hiddenKey: "notfollow_hidden_instagram_v1",
    });

    let followersData: any[] = [];
    let followingData: any[] = [];

    onFileChange("followersFile", (content) => {
      try {
        followersData.push(JSON.parse(content));
        setError("");
      } catch (error) {
        console.error("Error parsing followers file:", error);
        setError(
          "Error parsing followers file. Please make sure it is in the correct format."
        );
      }
    });

    onFileChange("followingFile", (content) => {
      try {
        followingData.push(JSON.parse(content));
        setError("");
      } catch (error) {
        console.error("Error parsing following file:", error);
        setError(
          "Error parsing following file. Please make sure it is in the correct format."
        );
      }
    });

    function extractUsernameFromInstagramHref(href: string): string {
      if (!href || typeof href !== "string") return "";
      try {
        const url = new URL(href);
        const parts = url.pathname.split("/").filter(Boolean);
        if (!parts.length) return "";
        if (parts[0] === "_u" && parts[1]) return parts[1];
        return parts[0];
      } catch {
        const parts = href.split("/").filter(Boolean);
        const uIndex = parts.indexOf("_u");
        if (uIndex !== -1 && parts[uIndex + 1]) return parts[uIndex + 1];
        return parts[parts.length - 1] || "";
      }
    }

    (window as any).processFiles = function () {
      if (!followersData.length || !followingData.length) {
        setError("Please upload both followers and following files.");
        return;
      }

      const followersSet = new Set<string>();
      followersData.forEach((data) => {
        data.forEach((f: any) => {
          const value = f?.string_list_data?.[0]?.value;
          if (value) {
            followersSet.add(String(value).toLowerCase());
          } else {
            console.error("Invalid follower entry:", f);
          }
        });
      });

      const followingList: Account[] = [];
      followingData.forEach((data) => {
        if (!data || !Array.isArray(data.relationships_following)) {
          console.error("Invalid following JSON root:", data);
          return;
        }

        data.relationships_following.forEach((f: any) => {
          const sld = f?.string_list_data?.[0];
          const username =
            (sld?.value as string) ||
            extractUsernameFromInstagramHref(sld?.href || "");

          if (username) {
            // Normalize to standard profile URL to avoid broken `/_u/` links
            followingList.push({
              username,
              href: `https://www.instagram.com/${username}/`,
            });
          } else {
            console.error("Invalid following entry:", f);
          }
        });
      });

      page.setResults(
        followingList.filter((f) => !followersSet.has(f.username.toLowerCase()))
      );
    };
  </script>
</Layout>
