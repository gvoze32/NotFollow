---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import UploadCard from "../components/upload/UploadCard.astro";
import FileInput from "../components/upload/FileInput.astro";
import HowToModal from "../components/HowToModal.astro";
import NonFollowersResults from "../components/results/NonFollowersResults.astro";
---

<Layout title="X NotFollow - Check Who Doesn't Follow You Back">
  <Navbar />

  <PageHero
    title="X NotFollow"
    subtitle="Upload your X data file to discover who doesn't follow you back"
  />

  <UploadCard>
    <FileInput
      id="followersFile"
      label="Followers File"
      accept=".js"
      hint="Select your follower.js file"
    />
    <FileInput
      id="followingFile"
      label="Following File"
      accept=".js"
      hint="Select your following.js file"
    />
  </UploadCard>

  <NonFollowersResults platformName="X" />

  <Footer />

  <HowToModal
    title="How to Get X (Twitter) Data Files"
    videoId="Pxndi7s5oY0"
    videoTitle="How to download X (Twitter) data (NotFollow tutorial)"
  />

  <script>
    import {
      createNotFollowPage,
      initModals,
      onFileChange,
      setError,
      type Account,
    } from "../scripts/notfollow-page";

    initModals();

    const page = createNotFollowPage({
      hiddenKey: "notfollow_hidden_x_v1",
    });

    let followersData: any[] = [];
    let followingData: any[] = [];

    function parseTwitterJSFile(content: string): any[] {
      // Twitter exports look like: window.YTD.follower.part0 = [ ... ]
      const jsonStart = content.indexOf("[");
      const jsonEnd = content.lastIndexOf("]") + 1;

      if (jsonStart === -1 || jsonEnd === 0) {
        throw new Error("Could not find JSON array in file");
      }

      return JSON.parse(content.substring(jsonStart, jsonEnd));
    }

    onFileChange("followersFile", (content) => {
      try {
        followersData = parseTwitterJSFile(content);
        setError("");
      } catch (error) {
        console.error("Error parsing followers file:", error);
        setError(
          "Error parsing followers file. Please make sure it is in the correct format."
        );
      }
    });

    onFileChange("followingFile", (content) => {
      try {
        followingData = parseTwitterJSFile(content);
        setError("");
      } catch (error) {
        console.error("Error parsing following file:", error);
        setError(
          "Error parsing following file. Please make sure it is in the correct format."
        );
      }
    });

    (window as any).processFiles = function () {
      if (!followersData.length || !followingData.length) {
        setError("Please upload both followers and following files.");
        return;
      }

      // Twitter format: [{ "follower": { "accountId": "...", "userLink": "..." } }]
      const followersSet = new Set<string>();
      followersData.forEach((entry: any) => {
        if (entry?.follower?.accountId) {
          followersSet.add(String(entry.follower.accountId).toLowerCase());
        }
      });

      const followingList: Account[] = [];
      followingData.forEach((entry: any) => {
        if (entry?.following?.accountId) {
          const accountId = entry.following.accountId;
          followingList.push({
            username: accountId,
            href: `https://twitter.com/intent/user?user_id=${accountId}`,
          });
        }
      });

      page.setResults(
        followingList.filter((f) => !followersSet.has(f.username.toLowerCase()))
      );
    };
  </script>
</Layout>
