---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import UploadCard from "../components/upload/UploadCard.astro";
import FileInput from "../components/upload/FileInput.astro";
import HowToModal from "../components/HowToModal.astro";
import NonFollowersResults from "../components/results/NonFollowersResults.astro";
---

<Layout title="TikTok NotFollow - Check Who Doesn't Follow You Back">
  <Navbar />

  <PageHero
    title="TikTok NotFollow"
    subtitle="Upload your TikTok data file to discover who doesn't follow you back"
  />

  <UploadCard howToLabel="How to Get File">
    <FileInput
      id="tiktokDataFile"
      label="TikTok Data File"
      accept=".json"
      hint="Select your user_data.json file"
    />
  </UploadCard>

  <NonFollowersResults platformName="TikTok" />

  <Footer />

  <HowToModal
    title="How to Get TikTok Data File"
    videoId="I1Nk4ag9naY"
    videoTitle="How to download TikTok data (NotFollow tutorial)"
  >
    <div
      class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white/40 dark:bg-black/10 p-3"
    >
      <p class="text-xs text-gray-700 dark:text-gray-300">
        Note: in <strong>Select data to download</strong>, make sure to check
        <strong>Profile and Settings</strong>, and ensure the download format is
        <strong>JSON</strong>.
      </p>
    </div>
  </HowToModal>

  <script>
    import {
      createNotFollowPage,
      initModals,
      onFileChange,
      setError,
      type Account,
    } from "../scripts/notfollow-page";

    initModals();

    const page = createNotFollowPage({
      hiddenKey: "notfollow_hidden_tiktok_v1",
    });

    let userData: any = null;

    onFileChange("tiktokDataFile", (content) => {
      try {
        userData = JSON.parse(content);
        setError("");
      } catch (error) {
        console.error("Error parsing TikTok data file:", error);
        setError(
          "Error parsing TikTok data file. Please make sure it is in the correct format."
        );
      }
    });

    (window as any).processFiles = function () {
      if (!userData) {
        setError(
          "Invalid JSON format. Please upload a valid TikTok user data file."
        );
        return;
      }

      try {
        const asArray = (value: any) => (Array.isArray(value) ? value : []);

        // Supports multiple TikTok export variants
        const followerRows = asArray(
          userData?.Profile?.["Follower List"]?.FansList ??
            userData?.Profile?.Follower?.FansList ??
            userData?.["Profile And Settings"]?.Follower?.FansList ??
            userData?.Follower?.FansList
        );

        const followingRows = asArray(
          userData?.Profile?.["Following List"]?.Following ??
            userData?.Profile?.Following?.Following ??
            userData?.["Profile And Settings"]?.Following?.Following ??
            userData?.Following?.Following
        );

        // If neither array exists, the file is likely a different TikTok export or wrong file.
        if (followerRows.length === 0 && followingRows.length === 0) {
          throw new Error(
            "TikTok data file structure not recognized: missing follower/following lists."
          );
        }

        const followersSet = new Set(
          followerRows
            .map((f: any) => f?.UserName)
            .filter((u: any) => typeof u === "string" && u.length > 0)
            .map((u: string) => u.toLowerCase())
        );

        const followingList: Account[] = followingRows
          .map((f: any) => f?.UserName)
          .filter((u: any) => typeof u === "string" && u.length > 0)
          .map((username: string) => ({
            username,
            href: `https://www.tiktok.com/@${username}`,
          }));

        page.setResults(
          followingList.filter(
            (f) => !followersSet.has(f.username.toLowerCase())
          )
        );
      } catch (error) {
        console.error("Error processing TikTok data:", error);
        setError(
          "Error processing data. Please make sure this is your TikTok user data JSON and it contains follower/following lists."
        );
      }
    };
  </script>
</Layout>
