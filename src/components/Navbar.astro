---
const currentPath = Astro.url.pathname;
---

<nav
  class="fixed top-4 left-0 right-0 z-50 flex justify-center px-4 pointer-events-none"
>
  <div
    class="relative overflow-hidden rounded-full bg-zinc-300/30 dark:bg-zinc-700/30 p-px max-w-full"
  >
    <div
      class="relative w-full rounded-full backdrop-blur-md bg-white/40 dark:bg-neutral-900/30 pointer-events-auto flex flex-col sm:flex-row gap-2 items-center justify-center px-3 py-2 sm:py-1.5"
    >
      <!-- Logo/Brand -->
      <a
        href="/"
        aria-label="Go to home page"
        class="flex items-center gap-2 px-2.5 py-1"
      >
        <span class="text-base font-semibold text-black dark:text-white"
          >NotFollow</span
        >
      </a>

      <span class="hidden sm:inline text-gray-400 dark:text-gray-600">|</span>

      <!-- Navigation Links -->
      <div class="flex flex-wrap gap-2 items-center justify-center">
        <a
          href="/instagram"
          class:list={[
            "px-2.5 py-1 text-sm flex items-center justify-center rounded-md transition-colors whitespace-nowrap",
            currentPath === "/instagram" || currentPath === "/instagram/"
              ? "bg-black/10 dark:bg-white/10 text-black dark:text-white font-medium"
              : "text-black dark:text-white hover:bg-black/5 dark:hover:bg-white/5",
          ]}
        >
          Instagram
        </a>
        <a
          href="/tiktok"
          class:list={[
            "px-2.5 py-1 text-sm flex items-center justify-center rounded-md transition-colors whitespace-nowrap",
            currentPath === "/tiktok" || currentPath === "/tiktok/"
              ? "bg-black/10 dark:bg-white/10 text-black dark:text-white font-medium"
              : "text-black dark:text-white hover:bg-black/5 dark:hover:bg-white/5",
          ]}
        >
          TikTok
        </a>
        <a
          href="/github"
          class:list={[
            "px-2.5 py-1 text-sm flex items-center justify-center rounded-md transition-colors whitespace-nowrap",
            currentPath === "/github" || currentPath === "/github/"
              ? "bg-black/10 dark:bg-white/10 text-black dark:text-white font-medium"
              : "text-black dark:text-white hover:bg-black/5 dark:hover:bg-white/5",
          ]}
        >
          GitHub
        </a>
        <a
          href="/x"
          class:list={[
            "px-2.5 py-1 text-sm flex items-center justify-center rounded-md transition-colors whitespace-nowrap",
            currentPath === "/x" || currentPath === "/x/"
              ? "bg-black/10 dark:bg-white/10 text-black dark:text-white font-medium"
              : "text-black dark:text-white hover:bg-black/5 dark:hover:bg-white/5",
          ]}
        >
          X
        </a>
      </div>

      <span class="hidden sm:inline text-gray-400 dark:text-gray-600">|</span>

      <!-- Theme Toggle Button -->
      <button
        id="theme-toggle"
        type="button"
        class="p-1.5 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
        aria-label="Toggle theme"
      >
        <svg
          id="theme-toggle-dark-icon"
          class="hidden w-5 h-5"
          fill="currentColor"
          viewBox="0 0 20 20"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
          ></path>
        </svg>
        <svg
          id="theme-toggle-light-icon"
          class="hidden w-5 h-5"
          fill="currentColor"
          viewBox="0 0 20 20"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
            fill-rule="evenodd"
            clip-rule="evenodd"></path>
        </svg>
      </button>
    </div>
  </div>
</nav>
